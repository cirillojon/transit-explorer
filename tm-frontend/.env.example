# Copy to `tm-frontend/.env` and fill in real values.
# DO NOT commit `.env`.
#
# Note: VITE_* values are baked into the production bundle and are visible
# to anyone who loads your site. They are NOT secrets — protect access with
# Firebase Auth domain restrictions + App Check, not by hiding the keys.

# Backend URL.
# In dev: leave blank (Vite proxy uses VITE_PROXY_URL below).
# In prod: full URL of deployed backend, e.g. https://api.your-domain.com
VITE_API_BASE_URL=

# Dev-only: target for the /api proxy in `vite dev` server.
VITE_PROXY_URL=http://localhost:8880

# Firebase web SDK config (Firebase Console → Project Settings → Your apps → Config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── Sentry (frontend) ───────────────────────────────────────
# DSN from Sentry → transit-explorer-frontend project → Settings → Client Keys.
# Leave blank to disable error reporting.
VITE_SENTRY_DSN=
# Optional environment label; falls back to "production" / "development".
#VITE_SENTRY_ENVIRONMENT=production
# Optional release identifier. On Vercel, prefer baking VERCEL_GIT_COMMIT_SHA in.
#VITE_SENTRY_RELEASE=
# Performance tracing rate (0.0–1.0). Default 0.1 in prod / 0 in dev.
#VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Session Replay sample rates (always-on session vs. error-triggered).
#VITE_SENTRY_REPLAYS_SESSION_RATE=0.0
#VITE_SENTRY_REPLAYS_ERROR_RATE=1.0

# ─── Sentry source-map upload (build-time only, NOT bundled) ─
# Set these only in Vercel project env (Build & Development) or your
# CI — never commit the auth token. Without all three, the build skips
# upload but still works.
#SENTRY_AUTH_TOKEN=sntrys_...
#SENTRY_ORG=transit-explorer
#SENTRY_PROJECT=transit-explorer-frontend
