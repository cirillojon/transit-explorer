# Copy to `tm-frontend/.env` and fill in real values.
# DO NOT commit `.env`.
#
# Note: VITE_* values are baked into the production bundle and are visible
# to anyone who loads your site. They are NOT secrets — protect access with
# Firebase Auth domain restrictions + App Check, not by hiding the keys.

# Backend URL.
# In dev: leave blank (Vite proxy uses VITE_PROXY_URL below).
# In prod: full URL of deployed backend, e.g. https://api.your-domain.com
VITE_API_BASE_URL=

# Dev-only: target for the /api proxy in `vite dev` server.
VITE_PROXY_URL=http://localhost:8880

# Firebase web SDK config (Firebase Console → Project Settings → Your apps → Config)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
